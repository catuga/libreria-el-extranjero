{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx ts-node $CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.ts",
            "timeout": 60,
            "statusMessage": "Checking TypeScript types..."
          }
        ]
      }
    ]
  }
}
